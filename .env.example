# Database
# Dev: SQLite file path (e.g. file:./prisma/dev.db)
# Prod: PostgreSQL connection string (e.g. postgresql://user:pass@host:5432/db)
DATABASE_URL="file:./prisma/dev.db"

# NextAuth / Auth.js v5
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-string-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Pusher (real-time WebSocket - crew coordination)
PUSHER_APP_ID="your-pusher-app-id"
PUSHER_KEY="your-pusher-key"
PUSHER_SECRET="your-pusher-secret"
PUSHER_CLUSTER="eu"
NEXT_PUBLIC_PUSHER_KEY="your-pusher-key"
NEXT_PUBLIC_PUSHER_CLUSTER="eu"

# UploadThing (file uploads - souvenirs photos)
UPLOADTHING_SECRET="sk_live_your-uploadthing-secret"
UPLOADTHING_APP_ID="your-uploadthing-app-id"

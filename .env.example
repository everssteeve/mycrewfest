# Database
# Dev: SQLite file path (e.g. file:./prisma/dev.db)
# Prod: Turso/libSQL cloud URL (e.g. libsql://your-db.turso.io?authToken=...)
DATABASE_URL="file:./prisma/dev.db"

# NextAuth / Auth.js v5
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-string-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional — credentials login works without it)
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Push notifications (VAPID)
# Generate with: npx web-push generate-vapid-keys --json
NEXT_PUBLIC_VAPID_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
# Subject hardcoded in src/app/api/cron/notify-upcoming/route.ts as mailto:contact@mycrewfest.app

# Cron endpoint auth (F21 — notify 15min before must-see events)
# Generate with: openssl rand -hex 32
# Call: GET /api/cron/notify-upcoming with Authorization: Bearer <CRON_SECRET>
# External cron (Hobby plan): https://cron-job.org or Upstash QStash every 10min
CRON_SECRET="your-cron-secret"
